# Good Jobs Backend — Environment Variables
# Copy this file to .env and fill in your values

# Server port (Render sets this automatically)
PORT=3000

# Environment
NODE_ENV=development

# (Future) When you add a real database, add its URL here:
# DATABASE_URL=your_database_url_here

# (Future) Email service keys for real form notifications:
# SENDGRID_API_KEY=your_key_here
# NOTIFICATION_EMAIL=hello@goodjobs.in
